generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  username            String               @unique
  passwordHash        String?
  role                UserRole             @default(USER)
  authProvider        AuthProvider         @default(LOCAL)
  isVerified          Boolean              @default(false)
  isMfaEnabled        Boolean              @default(false)
  mfaSecret           String?
  avatar              String?
  bio                 String?
  organization        String?
  failedLoginAttempts Int                  @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  aiProviders         AIProvider[]
  competitions        Competition[]        @relation("UserCompetitions")
  loginLogs           LoginLog[]
  passwordResetTokens PasswordResetToken[]
  refreshTokens       RefreshToken[]
  teamMemberships     TeamMember[]
  ownedTeams          Team[]               @relation("TeamOwner")

  @@index([email])
  @@index([username])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model LoginLog {
  id            String   @id @default(cuid())
  userId        String?
  email         String
  success       Boolean
  ipAddress     String?
  userAgent     String?
  errorMessage  String?
  failureReason String?
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([email])
  @@index([success])
  @@index([createdAt])
  @@map("login_logs")
}

model Team {
  id          String       @id @default(cuid())
  name        String
  description String?
  ownerId     String
  maxMembers  Int          @default(10)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  members     TeamMember[]
  owner       User         @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@map("teams")
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@map("team_members")
}

model AIProvider {
  id              String           @id @default(cuid())
  name            String
  type            AIProviderType
  apiKey          String
  endpoint        String?
  region          String?
  priority        Int              @default(0)
  isDefault       Boolean          @default(false)
  status          AIProviderStatus @default(ACTIVE)
  supportedModels String[]
  capabilities    String[]
  config          Json?
  totalRequests   Int              @default(0)
  totalTokensUsed Int              @default(0)
  lastUsedAt      DateTime?
  capabilityTags  String[]         @default([])
  scenarioTags    String[]         @default([])
  dailyTokenLimit Int?
  dailyCallLimit  Int?
  createdById     String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  createdBy       User             @relation(fields: [createdById], references: [id], onDelete: Cascade)
  requests        AIRequest[]

  @@index([createdById])
  @@index([type])
  @@index([status])
  @@index([isDefault])
  @@map("ai_providers")
}

model AIRequest {
  id           String      @id @default(cuid())
  providerId   String
  modelName    String
  modelType    AIModelType
  prompt       String
  response     String?
  tokensUsed   Int         @default(0)
  latencyMs    Int
  status       String      @default("success")
  errorMessage String?
  taskId       String?
  context      String?
  createdAt    DateTime    @default(now())
  provider     AIProvider  @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([taskId])
  @@index([createdAt])
  @@map("ai_requests")
}

model Competition {
  id          String          @id @default(cuid())
  name        String
  type        CompetitionType
  year        Int
  problemId   String
  folderPath  String
  description String?
  status      String          @default("active")
  startDate   DateTime?
  endDate     DateTime?
  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  createdBy   User            @relation("UserCompetitions", fields: [createdById], references: [id], onDelete: Cascade)
  problems    Problem[]

  @@index([createdById])
  @@index([type])
  @@index([year])
  @@map("competitions")
}

model Problem {
  id                String               @id @default(cuid())
  competitionId     String
  problemNumber     String
  title             String
  originalContent   String?
  translatedContent String?
  type              String?
  difficulty        String?
  keywords          String[]
  originalFileUrl   String?
  translatedFileUrl String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  deletedAt         DateTime?
  aiContents        AIGeneratedContent[]
  competition       Competition          @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  solutions         Solution[]

  @@unique([competitionId, problemNumber])
  @@index([competitionId])
  @@map("problems")
}

model Solution {
  id          String               @id @default(cuid())
  problemId   String
  type        SolutionType
  title       String
  description String?
  content     String?
  author      String?
  awardLevel  String?
  files       Json?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  deletedAt   DateTime?
  aiContents  AIGeneratedContent[]
  problem     Problem              @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId])
  @@index([type])
  @@map("solutions")
}

model AIGeneratedContent {
  id               String          @id @default(cuid())
  problemId        String
  solutionId       String?
  type             AIGeneratedType
  subProblemNumber String?
  content          String?
  metadata         Json?
  fileUrl          String?
  fileSize         Int?
  mimeType         String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  problem          Problem         @relation(fields: [problemId], references: [id], onDelete: Cascade)
  solution         Solution?       @relation(fields: [solutionId], references: [id])

  @@index([problemId])
  @@index([solutionId])
  @@index([type])
  @@map("ai_generated_contents")
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([category])
  @@map("system_settings")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

model LearningConfig {
  id                  String   @id @default(cuid())
  autoLearningEnabled Boolean  @default(true)
  dailyVideoTarget    Int      @default(3)
  learningStartTime   String   @default("00:00")
  learningEndTime     String   @default("06:00")
  allowedDaysOfWeek   String[]
  maxConcurrentTasks  Int      @default(2)
  pauseOnHighLoad     Boolean  @default(true)
  cpuThreshold        Int      @default(80)
  memoryThreshold     Int      @default(80)
  searchKeywords      String[] @default(["数学建模", "matlab", "python", "机器学习", "数据分析", "优化算法"])
  searchResultsLimit  Int      @default(10)
  minVideoDuration    Int      @default(300)
  maxVideoDuration    Int      @default(3600)
  minViewCount        Int      @default(1000)
  learningMode        String   @default("auto")
  requiredTags        String[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("learning_config")
}

model BilibiliVideo {
  id                  String              @id @default(cuid())
  bvid                String              @unique
  title               String
  description         String?
  author              String
  authorMid           String?
  duration            Int
  viewCount           Int                 @default(0)
  danmakuCount        Int                 @default(0)
  replyCount          Int                 @default(0)
  favoriteCount       Int                 @default(0)
  coinCount           Int                 @default(0)
  shareCount          Int                 @default(0)
  likeCount           Int                 @default(0)
  publishDate         DateTime?
  thumbnail           String?
  tags                String[]
  category            String?
  learningStatus      String              @default("pending")
  isFavorite          Boolean             @default(false)
  isIgnored           Boolean             @default(false)
  learningStartedAt   DateTime?
  learningCompletedAt DateTime?
  extractionResult    Json?
  error               String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  knowledgeEntries    VideoKnowledge[]
  learningTasks       VideoLearningTask[]

  @@index([bvid])
  @@index([learningStatus])
  @@index([author])
  @@index([publishDate])
  @@map("bilibili_videos")
}

model VideoLearningTask {
  id           String        @id @default(cuid())
  videoId      String
  taskType     String        @default("auto")
  taskSource   String?
  status       String        @default("pending")
  progress     Int           @default(0)
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  retryCount   Int           @default(0)
  maxRetries   Int           @default(3)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  video        BilibiliVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([status])
  @@index([taskType])
  @@map("video_learning_tasks")
}

model VideoKnowledge {
  id                   String               @id @default(cuid())
  videoId              String
  title                String
  content              String
  summary              String?
  category             String?
  tags                 String[]
  importance           String               @default("medium")
  timestamp            String               @default("")
  relevanceScore       Float                @default(0)
  createdAt            DateTime             @default(now())
  knowledgeBaseEntries KnowledgeBaseEntry[]
  video                BilibiliVideo        @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([category])
  @@index([importance])
  @@map("video_knowledge")
}

model KnowledgeBaseEntry {
  id               String          @id @default(cuid())
  title            String
  content          String
  summary          String?
  category         String
  subcategory      String?
  tags             String[]
  sourceType       String          @default("video")
  sourceId         String?
  videoKnowledgeId String?
  status           String          @default("active")
  isVerified       Boolean         @default(false)
  verificationNote String?
  usageCount       Int             @default(0)
  lastUsedAt       DateTime?
  qualityScore     Float           @default(0)
  userRating       Float?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  videoKnowledge   VideoKnowledge? @relation(fields: [videoKnowledgeId], references: [id])

  @@index([category])
  @@index([sourceType])
  @@index([status])
  @@index([tags])
  @@map("knowledge_base")
}

model LearningLog {
  id         String   @id @default(cuid())
  action     String
  taskType   String?
  videoId    String?
  videoTitle String?
  message    String
  status     String   @default("info")
  createdAt  DateTime @default(now())

  @@index([action])
  @@index([status])
  @@index([createdAt])
  @@map("learning_logs")
}

model AutoModelingTask {
  id               String           @id @default(cuid())
  taskId           String?          @unique
  competitionType  CompetitionType
  problemType      ProblemType
  problemTitle     String
  problemContent   String
  discussionId     String?          @unique
  discussionStatus DiscussionStatus @default(PENDING)
  codeGenerationId String?          @unique
  validationStatus ValidationStatus @default(PENDING)
  validationRounds Int              @default(0)
  paperId          String?          @unique
  paperStatus      PaperStatus      @default(DRAFT)
  overallStatus    OverallStatus    @default(PENDING)
  errorLog         String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  progress         Int              @default(0)
  codeGeneration   CodeGeneration?  @relation(fields: [codeGenerationId], references: [id])
  discussion       GroupDiscussion? @relation(fields: [discussionId], references: [id])
  paper            GeneratedPaper?  @relation(fields: [paperId], references: [id])
  validations      CodeValidation[]

  @@index([overallStatus])
  @@index([discussionStatus])
  @@index([validationStatus])
  @@map("auto_modeling_tasks")
}

model GroupDiscussion {
  id              String              @id @default(cuid())
  autoTaskId      String?             @unique
  discussionTitle String
  problemTitle    String
  competitionType CompetitionType
  problemType     ProblemType
  status          DiscussionStatus    @default(PENDING)
  currentRound    Int                 @default(0)
  maxRounds       Int                 @default(2)
  participants    Json
  summary         Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  autoTask        AutoModelingTask?
  messages        DiscussionMessage[]

  @@index([status])
  @@map("group_discussions")
}

model DiscussionMessage {
  id               String          @id @default(cuid())
  discussionId     String
  round            Int
  senderProviderId String
  senderName       String
  messageContent   String
  messageType      MessageType
  replyToMessageId String?
  coreAlgorithms   String?
  innovations      String?
  feasibility      String?
  disagreements    String?
  tokenCount       Int             @default(0)
  createdAt        DateTime        @default(now())
  discussion       GroupDiscussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  @@index([discussionId])
  @@index([senderProviderId])
  @@map("discussion_messages")
}

model CodeGeneration {
  id              String            @id @default(cuid())
  autoTaskId      String?           @unique
  discussionId    String?
  codeLanguage    CodeLanguage
  codeContent     String
  description     String?
  requirements    Json?
  qualityScore    Float?
  errorLog        String?
  executionStatus ExecutionStatus   @default(PENDING)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  autoTask        AutoModelingTask?
  validations     CodeValidation[]

  @@index([executionStatus])
  @@map("code_generations")
}

model CodeValidation {
  id                String           @id @default(cuid())
  autoTaskId        String
  codeGenerationId  String
  validationType    ValidationType
  status            ValidationStatus
  result            Json?
  errorMessage      String?
  validationDetails String?
  retried           Boolean          @default(false)
  createdAt         DateTime         @default(now())
  autoTask          AutoModelingTask @relation(fields: [autoTaskId], references: [id], onDelete: Cascade)
  codeGeneration    CodeGeneration   @relation(fields: [codeGenerationId], references: [id], onDelete: Cascade)

  @@index([autoTaskId])
  @@index([validationType])
  @@index([status])
  @@map("code_validations")
}

model GeneratedPaper {
  id           String            @id @default(cuid())
  autoTaskId   String?           @unique
  discussionId String?
  title        String
  content      String
  format       PaperFormat
  language     PaperLanguage
  sections     Json?
  wordCount    Int?
  status       PaperStatus       @default(DRAFT)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  autoTask     AutoModelingTask?

  @@index([status])
  @@map("generated_papers")
}

model CostControl {
  id           String   @id @default(cuid())
  providerId   String
  date         DateTime @db.Date
  tokensUsed   Int      @default(0)
  callsCount   Int      @default(0)
  costEstimate Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([providerId, date])
  @@index([providerId])
  @@index([date])
  @@map("cost_control")
}

model DiscussionCache {
  id               String   @id @default(cuid())
  cacheKey         String   @unique
  problemType      String
  problemContent   String
  discussionResult Json
  codeResult       Json?
  createdAt        DateTime @default(now())
  expiresAt        DateTime

  @@index([problemType])
  @@index([expiresAt])
  @@map("discussion_cache")
}

enum UserRole {
  ADMIN
  USER
  TEAM_LEAD
  TEAM_MEMBER
}

enum AuthProvider {
  LOCAL
  GOOGLE
  GITHUB
  SSO
}

enum CompetitionType {
  MCM
  ICM
  CUMCM
  SHENZHEN_CUP
  IMMC
  MATHORCUP
  EMMC
  TEDDY_CUP
  BLUE_BRIDGE_MATH
  REGIONAL
  OTHER
}

enum ProblemType {
  EVALUATION
  PREDICTION
  OPTIMIZATION
  CLASSIFICATION
  REGRESSION
  CLUSTERING
}

enum TaskStatus {
  PENDING
  PREPROCESSING
  MODELING
  EVALUATING
  REPORTING
  COMPLETED
  FAILED
}

enum AIProviderType {
  DEEPSEEK
  VOLCENGINE
  ALIYUN
  OPENAI
  ANTHROPIC
  ZHIPU
  BAIDU
  TENCENT
  HUNGYUAN
  MINIMAX
  GOOGLE_GEMINI
  AZURE_OPENAI
  ALIYUN_QWEN
  BAIDU_WENXIN
  CUSTOM
}

enum AIProviderStatus {
  ACTIVE
  INACTIVE
  ERROR
}

enum AIModelType {
  CHAT
  COMPLETION
  EMBEDDING
  IMAGE
  CODE_GENERATION
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum SolutionType {
  SYSTEM
  AWARD
  AI
}

enum AIGeneratedType {
  PAPER
  DATA
  CHART
}

enum DiscussionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum MessageType {
  INITIAL_THOUGHT
  COMMENT
  SUPPLEMENT
  SUMMARY
}

enum CodeLanguage {
  PYTHON
  MATLAB
}

enum ExecutionStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  TIMEOUT
}

enum ValidationType {
  BASIC
  RESULT
  VISUALIZATION
}

enum ValidationStatus {
  PENDING
  PASSED
  FAILED
  SKIPPED
}

enum PaperFormat {
  MCM
  CUMCM
}

enum PaperLanguage {
  CHINESE
  ENGLISH
}

enum PaperStatus {
  DRAFT
  COMPLETED
  FAILED
}

enum OverallStatus {
  PENDING
  DISCUSSING
  CODING
  VALIDATING
  RETRYING
  PAPER_GENERATING
  COMPLETED
  FAILED
}
