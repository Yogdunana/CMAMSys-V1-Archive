# Docker Compose 环境变量配置
# 复制此文件为 .env 并填入真实值

# 数据库配置
POSTGRES_PASSWORD=your_secure_postgres_password_here

# JWT 配置
JWT_SECRET=your_jwt_secret_minimum_32_characters_long
REFRESH_TOKEN_SECRET=your_refresh_token_secret_minimum_32

# 加密和安全
ENCRYPTION_KEY=your_encryption_key_minimum_32_characters
CSRF_SECRET=your_csrf_secret_minimum_32_characters_long
SESSION_SECRET=your_session_secret_minimum_32_characters

# 数据库连接（生产环境）
DATABASE_URL=postgresql://postgres:your_secure_postgres_password_here@db:5432/cmamsys

# 日志配置
LOG_FILE=/app/work/logs/bypass/app.log
LOG_LEVEL=info

# 可选：Sentry 错误追踪
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# 可选：AI Provider 配置
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
