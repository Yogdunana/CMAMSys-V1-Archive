# CMAMSys Enterprise Edition Environment Configuration
# Copy this file to .env.enterprise and update values

# ============================================
# Database Configuration
# ============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cmamsys

# ============================================
# JWT Configuration
# ============================================
# IMPORTANT: Change these values in production!
# Generate secure random keys: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-change-this-in-production

# ============================================
# Application Configuration
# ============================================
NODE_ENV=production
PORT=5000
HOSTNAME=0.0.0.0
CMAMSYS_EDITION=enterprise
DEPLOYMENT_MODE=self_hosted_paid

# ============================================
# Redis Configuration (Required for Enterprise)
# ============================================
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# ============================================
# S3 / Object Storage Configuration (Required for Enterprise)
# ============================================
# For MinIO (default)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=admin
S3_SECRET_KEY=admin123456
S3_BUCKET=cmamsys-uploads
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# For AWS S3 (alternative)
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY=your-aws-access-key
# S3_SECRET_KEY=your-aws-secret-key
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# S3_FORCE_PATH_STYLE=false

# For Aliyun OSS (alternative)
# S3_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# S3_ACCESS_KEY=your-aliyun-access-key
# S3_SECRET_KEY=your-aliyun-secret-key
# S3_BUCKET=your-bucket-name
# S3_REGION=oss-cn-hangzhou
# S3_FORCE_PATH_STYLE=true

# ============================================
# Email Configuration (Required for Enterprise)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@cmamsys.com
SMTP_NAME=CMAMSys

# ============================================
# License Configuration (Enterprise Edition)
# ============================================
# License key obtained from CMAMSys official channel
LICENSE_KEY=your-enterprise-license-key-here

# License server URL (default: https://license.cmamsys.com)
LICENSE_SERVER=https://license.cmamsys.com

# Offline mode (set to true if no internet access)
LICENSE_OFFLINE_MODE=false

# ============================================
# Feature Flags (Enterprise Edition)
# ============================================
# All features are enabled in Enterprise Edition
ENABLE_BASIC_MODELING=true
ENABLE_TEAM_COLLABORATION=true
ENABLE_REPORT_GENERATION=true
ENABLE_ADVANCED_ANALYTICS=true
ENABLE_AI_AUTO_SELECTION=true
ENABLE_ENTERPRISE_SSO=true
ENABLE_UNLIMITED_STORAGE=true
ENABLE_PRIORITY_SUPPORT=true
ENABLE_CUSTOM_BRANDING=true
ENABLE_API_ACCESS=true
ENABLE_WEBHOOKS=true
ENABLE_AUDIT_LOG=true
ENABLE_MULTI_TENANCY=true

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log
LOG_MAX_SIZE=10M
LOG_MAX_FILES=10
# Enable audit log (Enterprise only)
AUDIT_LOG_ENABLED=true
AUDIT_LOG_FILE=/app/logs/audit.log

# ============================================
# Upload Configuration
# ============================================
MAX_FILE_SIZE=1073741824  # 1GB in bytes (Enterprise: larger limit)
ALLOWED_FILE_TYPES=pdf,doc,docx,zip,rar,xlsx,csv,txt,md,png,jpg,jpeg,gif,mp4,avi,mkv

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=1000  # Higher limit for Enterprise

# ============================================
# Security Configuration
# ============================================
BCRYPT_ROUNDS=12
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=30d  # Longer for Enterprise
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# Enable MFA by default (Enterprise)
MFA_ENABLED=true
MFA_ISSUER=CMAMSys Enterprise

# ============================================
# SSO Configuration (Enterprise)
# ============================================
# SAML SSO
SSO_SAML_ENABLED=false
SSO_SAML_IDP_ENTITY_ID=
SSO_SAML_IDP_SSO_URL=
SSO_SAML_IDP_CERT=

# LDAP SSO
SSO_LDAP_ENABLED=false
SSO_LDAP_URL=
SSO_LDAP_BASE_DN=
SSO_LDAP_BIND_DN=
SSO_LDAP_BIND_PASSWORD=

# ============================================
# Admin User (Created on first run)
# ============================================
# Default admin email
ADMIN_EMAIL=admin@cmamsys.com
# Default admin password (CHANGE THIS!)
ADMIN_PASSWORD=admin123

# ============================================
# Monitoring Configuration (Enterprise)
# ============================================
# Enable metrics endpoint
ENABLE_METRICS=true
METRICS_PORT=9090

# Sentry error tracking (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ============================================
# Backup Configuration (Enterprise)
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=cmamsys-backups
