# Environment Configuration for CMAMSys

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/cmamsys"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_ACCESS_TOKEN_EXPIRY="15m"
JWT_REFRESH_TOKEN_EXPIRY="7d"
REFRESH_TOKEN_SECRET="your-super-secret-refresh-token-key"

# MFA (Multi-Factor Authentication)
MFA_ENABLED="true"
SMS_API_KEY="your-sms-api-key"
EMAIL_SMTP_HOST="smtp.gmail.com"
EMAIL_SMTP_PORT="587"
EMAIL_SMTP_USER="your-email@gmail.com"
EMAIL_SMTP_PASSWORD="your-app-password"

# Redis (Optional - for session management and caching)
REDIS_URL="redis://localhost:6379"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="10"

# Application
APP_NAME="CMAMSys"
APP_URL="http://localhost:5000"
APP_PORT="5000"
NODE_ENV="development"

# File Storage (S3 Compatible)
S3_ENDPOINT="https://s3.amazonaws.com"
S3_ACCESS_KEY_ID="your-access-key-id"
S3_SECRET_ACCESS_KEY="your-secret-access-key"
S3_REGION="us-east-1"
S3_BUCKET="cmamsys-uploads"

# Bilibili Learning (Optional)
# B站 Cookie，用于绕过反爬虫限制
# 获取方式：登录 B 站后，打开浏览器开发者工具，在 Application > Cookies 中复制所有 Cookie
BILIBILI_COOKIE=""
# 或者使用 B 站 API Key（如果有官方 API 权限）
BILIBILI_API_KEY=""

# AI Providers (Optional)
# 阿里云通义千问 API Key
# 获取方式：访问 https://dashscope.console.aliyun.com/apiKey 创建 API Key
ALIYUN_API_KEY=""

# DeepSeek API Key
# 获取方式：访问 https://platform.deepseek.com/api_keys 创建 API Key
DEEPSEEK_API_KEY=""

# OpenAI API Key
# 获取方式：访问 https://platform.openai.com/api-keys 创建 API Key
OPENAI_API_KEY=""

# Logging
LOG_LEVEL="info"
LOG_FILE="/app/work/logs/bypass/app.log"

# Security
CSRF_SECRET="your-csrf-secret-key"
BCRYPT_ROUNDS="12"
MAX_LOGIN_ATTEMPTS="5"
LOCKOUT_DURATION_MS="15*60*1000"

# Docker Deployment
DOCKER_REGISTRY="docker.io"
DOCKER_IMAGE_NAME="cmamsys"
DOCKER_IMAGE_TAG="latest"

# Monitoring (Optional)
SENTRY_DSN=""
