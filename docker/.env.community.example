# CMAMSys Community Edition Environment Configuration
# Copy this file to .env.community and update values

# ============================================
# Database Configuration
# ============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cmamsys

# ============================================
# JWT Configuration
# ============================================
# IMPORTANT: Change these values in production!
# Generate secure random keys: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-change-this-in-production

# ============================================
# Application Configuration
# ============================================
NODE_ENV=production
PORT=5000
HOSTNAME=0.0.0.0
CMAMSYS_EDITION=community
DEPLOYMENT_MODE=self_hosted

# ============================================
# Redis Configuration (Optional)
# ============================================
REDIS_URL=redis://redis:6379

# ============================================
# Email Configuration (Optional - for notifications)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@cmamsys.com

# ============================================
# Feature Flags (Community Edition)
# ============================================
# These features are enabled in Community Edition
ENABLE_BASIC_MODELING=true
ENABLE_TEAM_COLLABORATION=true
ENABLE_REPORT_GENERATION=true

# These features require Professional/Enterprise Edition
ENABLE_ADVANCED_ANALYTICS=false
ENABLE_AI_AUTO_SELECTION=false
ENABLE_ENTERPRISE_SSO=false
ENABLE_UNLIMITED_STORAGE=false
ENABLE_PRIORITY_SUPPORT=false

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log
LOG_MAX_SIZE=10M
LOG_MAX_FILES=10

# ============================================
# Upload Configuration
# ============================================
MAX_FILE_SIZE=104857600  # 100MB in bytes
ALLOWED_FILE_TYPES=pdf,doc,docx,zip,rar,xlsx,csv,txt,md

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Security Configuration
# ============================================
BCRYPT_ROUNDS=10
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# ============================================
# Admin User (Created on first run)
# ============================================
# Default admin email
ADMIN_EMAIL=admin@cmamsys.com
# Default admin password (CHANGE THIS!)
ADMIN_PASSWORD=REDACTED_PASSWORD
