# Environment Configuration for CMAMSys
# ⚠️ IMPORTANT: Replace all placeholder values with your actual values
# ⚠️ Do not commit .env file to version control

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# Authentication
# ⚠️ IMPORTANT: Generate strong secrets for production
# JWT_SECRET can be generated with: openssl rand -base64 32
JWT_SECRET=""
JWT_ACCESS_TOKEN_EXPIRY="15m"
JWT_REFRESH_TOKEN_EXPIRY="7d"
# REFRESH_TOKEN_SECRET can be generated with: openssl rand -base64 32
REFRESH_TOKEN_SECRET=""

# Encryption Key (for sensitive data like API Keys)
# ⚠️ IMPORTANT: This key must be kept secret! If lost, all encrypted data will be unrecoverable.
# Generate a secure key: openssl rand -base64 32
ENCRYPTION_KEY=""

# MFA (Multi-Factor Authentication)
MFA_ENABLED="true"
SMS_API_KEY=""
EMAIL_SMTP_HOST="smtp.gmail.com"
EMAIL_SMTP_PORT="587"
EMAIL_SMTP_USER=""
EMAIL_SMTP_PASSWORD=""

# Redis (Optional - for session management and caching)
REDIS_URL="redis://localhost:6379"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="10"

# Application
APP_NAME="CMAMSys"
APP_URL="http://localhost:5000"
APP_PORT="5000"
NODE_ENV="development"

# File Storage (S3 Compatible)
S3_ENDPOINT="https://s3.amazonaws.com"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="us-east-1"
S3_BUCKET=""

# Bilibili Learning (Optional)
BILIBILI_COOKIE=""
BILIBILI_API_KEY=""

# AI Providers (Optional)
ALIYUN_API_KEY=""
VOLCENGINE_API_KEY=""
DEEPSEEK_API_KEY=""
OPENAI_API_KEY=""

# Logging
LOG_LEVEL="info"
LOG_FILE="/app/work/logs/bypass/app.log"

# Security
# CSRF_SECRET can be generated with: openssl rand -base64 32
CSRF_SECRET=""
BCRYPT_ROUNDS="14"
MAX_LOGIN_ATTEMPTS="5"
LOCKOUT_DURATION_MS="15*60*1000"

# Docker Deployment
DOCKER_REGISTRY="docker.io"
DOCKER_IMAGE_NAME="cmamsys"
DOCKER_IMAGE_TAG="latest"

# Monitoring (Optional)
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ENVIRONMENT="production"
NEXT_PUBLIC_SENTRY_DSN=""

# API Versioning
API_DEFAULT_VERSION="v1"

# Sentry (Error Tracking)
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ENVIRONMENT="production"
NEXT_PUBLIC_SENTRY_DSN=""

# CSRF Protection
# CSRF_SECRET can be generated with: openssl rand -base64 32
CSRF_SECRET=""

# Performance Monitoring
ENABLE_WEB_VITALS=true
ENABLE_PERFORMANCE_MONITORING=true

# CORS
ALLOWED_ORIGINS="http://localhost:5000,https://your-domain.com"
ALLOWED_METHODS="GET,POST,PUT,DELETE,PATCH,OPTIONS"
ALLOWED_HEADERS="Content-Type,Authorization,X-CSRF-Token"

# Session
# SESSION_SECRET can be generated with: openssl rand -base64 32 (minimum 32 chars)
SESSION_SECRET=""
SESSION_MAX_AGE=604800000

# Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=".pdf,.doc,.docx,.txt,.csv,.xlsx,.xls,.png,.jpg,.jpeg,.gif"

# Testing
TEST_DATABASE_URL="postgresql://username:password@localhost:5432/database_test"
TEST_JWT_SECRET=""
TEST_CSRF_SECRET=""
