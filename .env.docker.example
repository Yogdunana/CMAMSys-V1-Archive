# 应用配置
APP_NAME=CMAMSys
APP_URL=http://localhost:5000
APP_PORT=5000
NODE_ENV=production

# 数据库配置
DATABASE_URL=postgresql://postgres:cmamsys_password@postgres:5432/cmamsys
DB_PORT=5432
DB_PASSWORD=cmamsys_password

# Redis 配置（可选）
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# 邮件配置（SMTP）
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=CMAMSys

# 安全密钥（生产环境必须修改）
JWT_SECRET=your_jwt_secret_key_minimum_32_characters
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key_minimum_32_characters
ENCRYPTION_KEY=your_encryption_key_minimum_32_characters
CSRF_SECRET=your_csrf_secret_key_minimum_32_characters
SESSION_SECRET=your_session_secret_key_minimum_32_characters

# 密码安全配置
BCRYPT_ROUNDS=14

# 登录安全配置
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MS=900000
SESSION_MAX_AGE=604800000

# API 配置
API_DEFAULT_VERSION=v1

# CORS 配置
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:80
ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization,X-CSRF-Token

# 文件上传配置
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.txt,.csv,.xlsx,.xls,.png,.jpg,.jpeg,.gif

# 路径配置
INSTALL_PATH=/app
DATA_PATH=/app/data
LOG_PATH=/app/logs
UPLOAD_PATH=/app/uploads
TEMP_PATH=/app/temp

# Nginx 配置（可选）
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
