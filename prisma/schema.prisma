generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String         @id @default(cuid())
  email               String         @unique
  username            String         @unique
  passwordHash        String?
  role                UserRole       @default(USER)
  authProvider        AuthProvider   @default(LOCAL)
  isVerified          Boolean        @default(false)
  isMfaEnabled        Boolean        @default(false)
  mfaSecret           String?
  avatar              String?
  bio                 String?
  organization        String?
  failedLoginAttempts Int            @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  deletedAt           DateTime?
  aiProviders         AIProvider[]
  competitions        Competition[]  @relation("UserCompetitions")
  refreshTokens       RefreshToken[]
  teamMemberships     TeamMember[]
  ownedTeams          Team[]         @relation("TeamOwner")

  @@index([email])
  @@index([username])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

model Team {
  id          String       @id @default(cuid())
  name        String
  description String?
  ownerId     String
  maxMembers  Int          @default(10)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  members     TeamMember[]
  owner       User         @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@map("teams")
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@map("team_members")
}

model AIProvider {
  id               String           @id @default(cuid())
  name             String
  type             AIProviderType
  apiKey           String
  endpoint         String?
  region           String?
  priority         Int              @default(0)
  isDefault        Boolean          @default(false)
  status           AIProviderStatus @default(ACTIVE)
  supportedModels  String[]
  capabilities     String[]
  config           Json?
  totalRequests    Int              @default(0)
  totalTokensUsed  Int              @default(0)
  lastUsedAt       DateTime?
  // 全自动化扩展字段
  capabilityTags   String[]         @default([]) // 能力标签：数学建模算法、代码生成、数据预处理、优化算法、统计分析
  scenarioTags     String[]         @default([]) // 场景标签：美赛优化题、国赛预测题、数据分析、可视化设计
  dailyTokenLimit  Int?             // 每日 Token 上限
  dailyCallLimit   Int?             // 每日调用次数上限
  createdById      String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?
  createdBy        User             @relation(fields: [createdById], references: [id], onDelete: Cascade)
  requests         AIRequest[]

  @@index([createdById])
  @@index([type])
  @@index([status])
  @@index([isDefault])
  @@map("ai_providers")
}

model AIRequest {
  id           String      @id @default(cuid())
  providerId   String
  modelName    String
  modelType    AIModelType
  prompt       String
  response     String?
  tokensUsed   Int         @default(0)
  latencyMs    Int
  status       String      @default("success")
  errorMessage String?
  taskId       String?
  context      String?
  createdAt    DateTime    @default(now())
  provider     AIProvider  @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@index([taskId])
  @@index([createdAt])
  @@map("ai_requests")
}

model Competition {
  id          String          @id @default(cuid())
  name        String
  type        CompetitionType
  year        Int
  problemId   String
  folderPath  String
  description String?
  status      String          @default("active")
  startDate   DateTime?
  endDate     DateTime?
  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  createdBy   User            @relation("UserCompetitions", fields: [createdById], references: [id], onDelete: Cascade)
  problems    Problem[]

  @@index([createdById])
  @@index([type])
  @@index([year])
  @@map("competitions")
}

model Problem {
  id                String   @id @default(cuid())
  competitionId     String
  problemNumber     String   // A, B, C, D 等
  title             String   // 题目标题
  originalContent   String?  @db.Text // 题目原文
  translatedContent String?  @db.Text // 翻译内容
  type              String?  // 题目类型
  difficulty        String?  // 难度：简单/中等/困难
  keywords          String[] // 关键词
  originalFileUrl   String?  // 原文文件URL
  translatedFileUrl String?  // 翻译文件URL
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?

  competition       Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  solutions         Solution[]
  aiContents        AIGeneratedContent[]

  @@unique([competitionId, problemNumber])
  @@index([competitionId])
  @@map("problems")
}

model Solution {
  id              String   @id @default(cuid())
  problemId       String
  type            SolutionType // system, award, ai
  title           String
  description     String?  @db.Text
  content         String?  @db.Text
  author          String?
  awardLevel      String?  // 获奖等级：特等奖/一等奖/二等奖/三等奖
  files           Json?    // 相关文件列表
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  problem         Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  aiContents      AIGeneratedContent[]

  @@index([problemId])
  @@index([type])
  @@map("solutions")
}

model AIGeneratedContent {
  id                String   @id @default(cuid())
  problemId         String
  solutionId        String?
  type              AIGeneratedType // paper, data, chart
  subProblemNumber  String?  // 子问题编号：1, 2, 3 等
  content           String?  @db.Text
  metadata          Json?    // 元数据：模型、参数、配置等
  fileUrl           String?  // 文件URL
  fileSize          Int?     // 文件大小
  mimeType          String?  // MIME类型
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  problem           Problem   @relation(fields: [problemId], references: [id], onDelete: Cascade)
  solution          Solution? @relation(fields: [solutionId], references: [id])

  @@index([problemId])
  @@index([solutionId])
  @@index([type])
  @@map("ai_generated_contents")
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([category])
  @@map("system_settings")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

model LearningConfig {
  id                  String   @id @default(cuid())
  autoLearningEnabled Boolean  @default(true)
  dailyVideoTarget    Int      @default(3)
  learningStartTime   String   @default("00:00")
  learningEndTime     String   @default("06:00")
  allowedDaysOfWeek   String[]
  maxConcurrentTasks  Int      @default(2)
  pauseOnHighLoad     Boolean  @default(true)
  cpuThreshold        Int      @default(80)
  memoryThreshold     Int      @default(80)
  searchKeywords      String[] @default(["数学建模", "matlab", "python", "机器学习", "数据分析", "优化算法"])
  searchResultsLimit  Int      @default(10)
  minVideoDuration    Int      @default(300)
  maxVideoDuration    Int      @default(3600)
  minViewCount        Int      @default(1000)
  learningMode        String   @default("auto")
  requiredTags        String[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("learning_config")
}

model BilibiliVideo {
  id                  String              @id @default(cuid())
  bvid                String              @unique
  title               String
  description         String?
  author              String
  authorMid           String?
  duration            Int
  viewCount           Int                 @default(0)
  danmakuCount        Int                 @default(0)
  replyCount          Int                 @default(0)
  favoriteCount       Int                 @default(0)
  coinCount           Int                 @default(0)
  shareCount          Int                 @default(0)
  likeCount           Int                 @default(0)
  publishDate         DateTime?
  thumbnail           String?
  tags                String[]
  category            String?
  learningStatus      String              @default("pending")
  isFavorite          Boolean             @default(false)
  isIgnored           Boolean             @default(false)
  learningStartedAt   DateTime?
  learningCompletedAt DateTime?
  extractionResult    Json?
  error               String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  knowledgeEntries    VideoKnowledge[]
  learningTasks       VideoLearningTask[]

  @@index([bvid])
  @@index([learningStatus])
  @@index([author])
  @@index([publishDate])
  @@map("bilibili_videos")
}

model VideoLearningTask {
  id           String        @id @default(cuid())
  videoId      String
  taskType     String        @default("auto")
  taskSource   String?
  status       String        @default("pending")
  progress     Int           @default(0)
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  retryCount   Int           @default(0)
  maxRetries   Int           @default(3)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  video        BilibiliVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([status])
  @@index([taskType])
  @@map("video_learning_tasks")
}

model VideoKnowledge {
  id                   String               @id @default(cuid())
  videoId              String
  title                String
  content              String
  summary              String?
  category             String?
  tags                 String[]
  importance           String               @default("medium")
  timestamp            String               @default("")
  relevanceScore       Float                @default(0)
  createdAt            DateTime             @default(now())
  knowledgeBaseEntries KnowledgeBaseEntry[]
  video                BilibiliVideo        @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([category])
  @@index([importance])
  @@map("video_knowledge")
}

model KnowledgeBaseEntry {
  id               String          @id @default(cuid())
  title            String
  content          String
  summary          String?
  category         String
  subcategory      String?
  tags             String[]
  sourceType       String          @default("video")
  sourceId         String?
  videoKnowledgeId String?
  status           String          @default("active")
  isVerified       Boolean         @default(false)
  verificationNote String?
  usageCount       Int             @default(0)
  lastUsedAt       DateTime?
  qualityScore     Float           @default(0)
  userRating       Float?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  videoKnowledge   VideoKnowledge? @relation(fields: [videoKnowledgeId], references: [id])

  @@index([category])
  @@index([sourceType])
  @@index([status])
  @@index([tags])
  @@map("knowledge_base")
}

model LearningLog {
  id         String   @id @default(cuid())
  action     String
  taskType   String?
  videoId    String?
  videoTitle String?
  message    String
  status     String   @default("info")
  createdAt  DateTime @default(now())

  @@index([action])
  @@index([status])
  @@index([createdAt])
  @@map("learning_logs")
}

enum UserRole {
  ADMIN
  USER
  TEAM_LEAD
  TEAM_MEMBER
}

enum AuthProvider {
  LOCAL
  GOOGLE
  GITHUB
  SSO
}

enum CompetitionType {
  MCM
  ICM
  CUMCM
  SHENZHEN_CUP
  IMMC
  MATHORCUP
  EMMC
  TEDDY_CUP
  BLUE_BRIDGE_MATH
  REGIONAL
  OTHER
}

enum ProblemType {
  EVALUATION
  PREDICTION
  OPTIMIZATION
  CLASSIFICATION
  REGRESSION
  CLUSTERING
}

enum TaskStatus {
  PENDING
  PREPROCESSING
  MODELING
  EVALUATING
  REPORTING
  COMPLETED
  FAILED
}

enum AIProviderType {
  DEEPSEEK
  VOLCENGINE
  ALIYUN
  OPENAI
  ANTHROPIC
  ZHIPU
  BAIDU
  TENCENT
  HUNGYUAN
  MINIMAX
  GOOGLE_GEMINI
  AZURE_OPENAI
  ALIYUN_QWEN
  BAIDU_WENXIN
  CUSTOM
}

enum AIProviderStatus {
  ACTIVE
  INACTIVE
  ERROR
}

enum AIModelType {
  CHAT
  COMPLETION
  EMBEDDING
  IMAGE
  CODE_GENERATION
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum SolutionType {
  SYSTEM      // 建模系统解法
  AWARD       // 获奖解法
  AI          // AI 生成的解法
}

enum AIGeneratedType {
  PAPER       // AI 论文
  DATA        // AI 生成的数据
  CHART       // AI 生成的图表
}

// ==================== 全自动化模块新增枚举类型 ====================

enum DiscussionStatus {
  PENDING       // 待开始
  IN_PROGRESS   // 进行中
  COMPLETED     // 已完成
  FAILED        // 失败
}

enum MessageType {
  INITIAL_THOUGHT  // 初始思路
  COMMENT         // 点评
  SUPPLEMENT      // 补充
  SUMMARY         // 总结
}

enum CodeLanguage {
  PYTHON
  MATLAB
}

enum ExecutionStatus {
  PENDING       // 待执行
  RUNNING       // 执行中
  SUCCESS       // 执行成功
  FAILED        // 执行失败
  TIMEOUT       // 超时
}

enum ValidationType {
  BASIC          // 基础校验（语法、运行错误）
  RESULT         // 结果合理性校验
  VISUALIZATION  // 可视化质量校验
}

enum ValidationStatus {
  PENDING       // 待校验
  PASSED        // 通过
  FAILED        // 失败
  SKIPPED       // 跳过
}

enum PaperFormat {
  MCM    // 美赛格式
  CUMCM  // 国赛格式
}

enum PaperLanguage {
  CHINESE
  ENGLISH
}

enum PaperStatus {
  DRAFT      // 草稿
  COMPLETED  // 已完成
  FAILED     // 生成失败
}

enum OverallStatus {
  PENDING         // 待开始
  DISCUSSING      // 讨论中
  CODING          // 代码生成中
  VALIDATING      // 校验中
  RETRYING        // 回溯中
  PAPER_GENERATING // 论文生成中
  COMPLETED       // 已完成
  FAILED          // 失败
}

// ==================== 全自动化模块数据模型 ====================

// 自动化建模任务（继承并扩展 ModelingTask）
model AutoModelingTask {
  id                String                @id @default(cuid())
  taskId            String?               @unique // 关联到 ModelingTask
  competitionType   CompetitionType
  problemType       ProblemType
  problemTitle      String
  problemContent    String               @db.Text
  discussionId      String?               @unique // 关联到讨论记录
  discussionStatus  DiscussionStatus      @default(PENDING)
  codeGenerationId  String?               @unique // 关联到代码生成记录
  validationStatus  ValidationStatus      @default(PENDING)
  validationRounds  Int                   @default(0) // 回溯次数
  paperId           String?               @unique // 关联到论文
  paperStatus       PaperStatus           @default(DRAFT)
  overallStatus     OverallStatus         @default(PENDING)
  errorLog          String?               @db.Text
  progress          Int                   @default(0) // 任务进度 0-100
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  discussion        GroupDiscussion?      @relation(fields: [discussionId], references: [id])
  codeGeneration    CodeGeneration?       @relation(fields: [codeGenerationId], references: [id])
  validations       CodeValidation[]
  paper             GeneratedPaper?       @relation(fields: [paperId], references: [id])

  @@index([overallStatus])
  @@index([discussionStatus])
  @@index([validationStatus])
  @@index([paperStatus])
  @@index([progress])
  @@index([createdAt])
  @@map("auto_modeling_tasks")
}

// 群聊讨论记录
model GroupDiscussion {
  id                String              @id @default(cuid())
  autoTaskId        String?             @unique // 关联到自动化任务
  discussionTitle   String
  problemTitle      String
  competitionType   CompetitionType
  problemType       ProblemType
  status            DiscussionStatus    @default(PENDING)
  currentRound      Int                 @default(0) // 当前讨论轮数
  maxRounds         Int                 @default(2) // 最大讨论轮数
  participants      Json                // 参与的 AI Provider 列表
  summary           Json?               // 观点对比总结（核心算法/创新点/分歧点）
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  autoTask          AutoModelingTask?   @relation
  messages          DiscussionMessage[]

  @@index([status])
  @@index([autoTaskId])
  @@index([createdAt])
  @@map("group_discussions")
}

// 讨论消息
model DiscussionMessage {
  id                String              @id @default(cuid())
  discussionId      String
  round             Int                 // 讨论轮数
  senderProviderId  String              // 发言的 AI Provider ID
  senderName        String              // 发言者名称
  messageContent    String              @db.Text
  messageType       MessageType         // INITIAL_THOUGHT(初始思路)、COMMENT(点评)、SUPPLEMENT(补充)
  replyToMessageId  String?             // 回复的消息 ID
  coreAlgorithms    String?             @db.Text // 提取的核心算法
  innovations       String?             @db.Text // 提取的创新点
  feasibility       String?             @db.Text // 提取的可行性分析
  disagreements     String?             @db.Text // 分歧点（如果有点评）
  tokenCount        Int                 @default(0)
  createdAt         DateTime            @default(now())

  discussion        GroupDiscussion     @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  @@index([discussionId])
  @@index([round])
  @@index([senderProviderId])
  @@index([createdAt])
  @@map("discussion_messages")
}

// 代码生成记录
model CodeGeneration {
  id                String              @id @default(cuid())
  autoTaskId        String?             @unique // 关联到自动化任务
  discussionId      String?             // 关联到讨论记录
  codeLanguage      CodeLanguage        // PYTHON, MATLAB
  codeContent       String              @db.Text
  description       String?             @db.Text // 代码说明
  requirements      Json?               // 思路要求（核心算法、创新点等）
  qualityScore      Float?              // 代码质量评分 0-100
  errorLog          String?             @db.Text
  executionStatus   ExecutionStatus     @default(PENDING)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  autoTask          AutoModelingTask?   @relation
  validations       CodeValidation[]

  @@index([autoTaskId])
  @@index([discussionId])
  @@index([executionStatus])
  @@index([createdAt])
  @@map("code_generations")
}

// 代码校验记录
model CodeValidation {
  id                String              @id @default(cuid())
  autoTaskId        String
  codeGenerationId  String
  validationType    ValidationType      // BASIC(基础校验)、RESULT(结果校验)、VISUALIZATION(可视化校验)
  status            ValidationStatus    // PENDING, PASSED, FAILED
  result            Json?               // 校验结果详情
  errorMessage      String?             @db.Text
  validationDetails String?             @db.Text // 详细校验报告
  retried           Boolean             @default(false) // 是否已重试
  createdAt         DateTime            @default(now())

  autoTask          AutoModelingTask    @relation(fields: [autoTaskId], references: [id], onDelete: Cascade)
  codeGeneration    CodeGeneration      @relation(fields: [codeGenerationId], references: [id], onDelete: Cascade)

  @@index([autoTaskId])
  @@index([validationType])
  @@index([status])
  @@map("code_validations")
}

// 生成的论文
model GeneratedPaper {
  id                String              @id @default(cuid())
  autoTaskId        String?             @unique // 关联到自动化任务
  discussionId      String?             // 关联到讨论记录
  title             String
  content           String              @db.Text // Markdown 格式
  format            PaperFormat         // MCM(美赛), CUMCM(国赛)
  language          PaperLanguage       // CHINESE, ENGLISH
  sections          Json?               // 论文结构（赛题分析、模型假设等）
  wordCount         Int?                // 字数统计
  status            PaperStatus         @default(DRAFT)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  autoTask          AutoModelingTask?   @relation

  @@index([autoTaskId])
  @@index([status])
  @@index([createdAt])
  @@map("generated_papers")
}

// 成本管控记录
model CostControl {
  id                String              @id @default(cuid())
  providerId        String
  date              DateTime            @db.Date
  tokensUsed        Int                 @default(0)
  callsCount        Int                 @default(0)
  costEstimate      Float?              // 预估成本
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([providerId, date])
  @@index([providerId])
  @@index([date])
  @@map("cost_control")
}

// 缓存记录
model DiscussionCache {
  id                String              @id @default(cuid())
  cacheKey          String              @unique
  problemType       String
  problemContent    String              @db.Text
  discussionResult  Json                // 缓存的讨论结果
  codeResult        Json?               // 缓存的代码生成结果
  createdAt         DateTime            @default(now())
  expiresAt         DateTime

  @@index([problemType])
  @@index([expiresAt])
  @@map("discussion_cache")
}
