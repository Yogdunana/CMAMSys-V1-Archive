# ⚠️ ARCHIVED REPOSITORY - FOR LEARNING REFERENCE ONLY
# This repository has been archived and is no longer actively maintained.
# DO NOT use these configurations in production without thorough security review.
# Replace all default passwords and secret keys with your own secure values.
#
# Attribution: CMAMSys (CompetiMath AutoModel System)
# Repository: https://github.com/Yogdunana/CMAMSys-V1-Archive
#

# Environment Configuration for CMAMSys (PostgreSQL - Production)

# Database (PostgreSQL for production)
# Development: Use local PostgreSQL instance
# Production: Use managed PostgreSQL service (AWS RDS, Google Cloud SQL, etc.)
DATABASE_URL="postgresql://cmamsys_user:your_password_here@localhost:5432/cmamsys?schema=public"

# Alternative: Use environment-specific database URL
# DATABASE_URL="${DATABASE_URL:-postgresql://cmamsys_user:your_password_here@localhost:5432/cmamsys?schema=public}"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_ACCESS_TOKEN_EXPIRY="15m"
JWT_REFRESH_TOKEN_EXPIRY="7d"
REFRESH_TOKEN_SECRET="your-super-secret-refresh-token-key"

# Password Reset Token
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES="60"

# Encryption Key (for sensitive data like API Keys)
# IMPORTANT: This key must be kept secret! If lost, all encrypted data will be unrecoverable.
# Generate a secure key: openssl rand -base64 32
ENCRYPTION_KEY="your-256-bit-encryption-key-generate-with-openssl"

# Admin Account
ADMIN_EMAIL="admin@example.com"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="your-secure-password-here"

# MFA (Multi-Factor Authentication)
MFA_ENABLED="true"

# Application
APP_NAME="CMAMSys"
APP_URL="http://localhost:5000"
APP_PORT="5000"
NODE_ENV="development"

# Security
BCRYPT_ROUNDS="12"
MAX_LOGIN_ATTEMPTS="5"
LOCKOUT_DURATION_MS="900000"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="900000"  # 15 minutes
RATE_LIMIT_MAX_ATTEMPTS="5"    # Max 5 requests per window
PASSWORD_RESET_MAX_ATTEMPTS="3" # Max 3 reset requests per hour

# Email Service (Local/Development)
MAILER_ENABLED="true"
MAILER_HOST="localhost"
MAILER_PORT="1025"
EMAIL_FROM="noreply@cmamsys.com"

# Email Service (Production SMTP)
# SMTP_HOST="smtp.sendgrid.net"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="apikey"
# SMTP_PASSWORD="your-api-key-here"

# Logging
LOG_LEVEL="info"
LOG_FILE="/app/work/logs/bypass/app.log"

# CSRF
CSRF_SECRET="your-csrf-secret-key-2024-secure-256-bit"

# Sentry (Error Tracking) - Self-Hosted
# 本地自托管 Sentry 配置
# 启动 Sentry: cd docker/sentry && docker-compose up -d
# 访问: http://localhost:9000
SENTRY_DSN="http://your-dsn@localhost:9000/your-project"
SENTRY_AUTH_TOKEN="your-sentry-auth-token-here"
SENTRY_ENVIRONMENT="development"
SENTRY_ORGANIZATION="your-org"
SENTRY_PROJECT="your-project"
SENTRY_RELEASE="v1.0.0"
NEXT_PUBLIC_SENTRY_DSN="http://your-dsn@localhost:9000/your-project"

# API Versioning
API_DEFAULT_VERSION="v1"

# Performance Monitoring
ENABLE_WEB_VITALS=true
ENABLE_PERFORMANCE_MONITORING=true

# CORS
ALLOWED_ORIGINS="http://localhost:5000,https://your-domain.com"
ALLOWED_METHODS="GET,POST,PUT,DELETE,PATCH,OPTIONS"
ALLOWED_HEADERS="Content-Type,Authorization,X-CSRF-Token"

# Session
SESSION_SECRET="your-super-secret-session-key-2024-secure-256-bit"
SESSION_MAX_AGE=604800000

# Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=".pdf,.doc,.docx,.txt,.csv,.xlsx,.xls,.png,.jpg,.jpeg,.gif"

# Testing
TEST_DATABASE_URL="postgresql://cmamsys_user:your_password_here@localhost:5432/cmamsys_test?schema=public"
TEST_JWT_SECRET="test-jwt-secret-for-testing-only-256-bit"
TEST_CSRF_SECRET="test-csrf-secret-for-testing-only-256-bit"

# Redis Configuration
REDIS_URL="redis://localhost:6379"
REDIS_ENABLED="true"
ENABLE_DISTRIBUTED_RATE_LIMIT="true"

# Cleanup Tasks
CLEANUP_EXPIRED_TOKENS_ENABLED="true"
CLEANUP_EXPIRED_TOKENS_INTERVAL_HOURS="24"  # Run cleanup every 24 hours
CLEANUP_LOGIN_LOGS_DAYS="90"  # Keep login logs for 90 days
CLEANUP_AUDIT_LOGS_DAYS="365"  # Keep audit logs for 1 year

# PostgreSQL Configuration (for production)
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"
POSTGRES_USER="cmamsys_user"
POSTGRES_PASSWORD="your_password_here"
POSTGRES_DB="cmamsys"
