# ⚠️ ARCHIVED REPOSITORY - FOR LEARNING REFERENCE ONLY
# This repository has been archived and is no longer actively maintained.
# DO NOT use these configurations in production without thorough security review.
# Replace all default passwords and secret keys with your own secure values.
#
# Attribution: CMAMSys (CompetiMath AutoModel System)
# Repository: https://github.com/Yogdunana/CMAMSys-V1-Archive
#

# Environment Configuration for Production

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"
JWT_ACCESS_TOKEN_EXPIRY="15m"
JWT_REFRESH_TOKEN_EXPIRY="7d"
REFRESH_TOKEN_SECRET="your-super-secret-refresh-token-key-minimum-32-characters-long"

# Password Reset Token
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES="60"

# Encryption Key (for sensitive data like API Keys)
# IMPORTANT: This key must be kept secret! If lost, all encrypted data will be unrecoverable.
# Generate a secure key: openssl rand -base64 32
ENCRYPTION_KEY="your-256-bit-encryption-key-change-in-production"

# MFA (Multi-Factor Authentication)
MFA_ENABLED="true"

# Application
APP_NAME="CMAMSys"
APP_URL="https://your-domain.com"
APP_PORT="5000"
NODE_ENV="production"

# Security
BCRYPT_ROUNDS="12"
MAX_LOGIN_ATTEMPTS="5"
LOCKOUT_DURATION_MS="900000"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="900000"  # 15 minutes
RATE_LIMIT_MAX_ATTEMPTS="5"    # Max 5 requests per window
PASSWORD_RESET_MAX_ATTEMPTS="3" # Max 3 reset requests per hour

# Email Service (Production SMTP)
MAILER_ENABLED="true"
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="apikey"
SMTP_PASSWORD="SG.your-sendgrid-api-key"
EMAIL_FROM="\"CMAMSys\" <noreply@your-domain.com>"

# Logging
LOG_LEVEL="info"
LOG_FILE="/app/work/logs/bypass/app.log"

# CSRF
CSRF_SECRET="your-csrf-secret-key-256-bit-change-in-production"

# Sentry (Error Tracking) - Optional
# SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
# SENTRY_AUTH_TOKEN="your-sentry-auth-token"
# SENTRY_ENVIRONMENT="production"
# SENTRY_ORGANIZATION="cmamsys"
# SENTRY_PROJECT="cmamsys-web"
# SENTRY_RELEASE="v1.0.0"
# NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"

# API Versioning
API_DEFAULT_VERSION="v1"

# Performance Monitoring
ENABLE_WEB_VITALS=true
ENABLE_PERFORMANCE_MONITORING=true

# CORS
ALLOWED_ORIGINS="https://your-domain.com"
ALLOWED_METHODS="GET,POST,PUT,DELETE,PATCH,OPTIONS"
ALLOWED_HEADERS="Content-Type,Authorization,X-CSRF-Token"

# Session
SESSION_SECRET="your-session-secret-key-256-bit-change-in-production"
SESSION_MAX_AGE=604800000

# Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=".pdf,.doc,.docx,.txt,.csv,.xlsx,.xls,.png,.jpg,.jpeg,.gif"

# Redis Configuration (Optional - for distributed rate limiting)
# REDIS_URL="redis://localhost:6379"
# REDIS_ENABLED="false"
# ENABLE_DISTRIBUTED_RATE_LIMIT="false"

# Cleanup Tasks
CLEANUP_EXPIRED_TOKENS_ENABLED="true"
CLEANUP_EXPIRED_TOKENS_INTERVAL_HOURS="24"
CLEANUP_LOGIN_LOGS_DAYS="90"
CLEANUP_AUDIT_LOGS_DAYS="365"
